# Ruby Core Production Environment Configuration
# Copy this file to .env and fill in values
# IMPORTANT: Never commit .env files with real values to Git!
#
# Production secrets MUST come from Vault (ADR-0015)
# This file is for non-sensitive configuration only.

# =============================================================================
# Docker Compose
# =============================================================================
COMPOSE_PROJECT_NAME=ruby-core-prod

# =============================================================================
# Vault Configuration (ADR-0015)
# =============================================================================
# General-purpose Vault on this node (shared across environments)
# Services reach Vault via the vault-ruby-core-prod Docker network
#
# NOTE: Phase 2 uses static tokens. Future phases will migrate to AppRole (ADR-0015).
VAULT_TOKEN=<your-vault-token>

# =============================================================================
# NATS Configuration
# =============================================================================
# NATS server URL (TLS required)
NATS_URL=tls://nats:4222

# Require mTLS for all NATS connections (also set in compose environment)
NATS_REQUIRE_MTLS=true

# TLS client certificates are fetched from Vault at runtime (ADR-0015, ADR-0018)
# Override the Vault path if needed (defaults are per-service in compose):
# VAULT_TLS_PATH_GATEWAY=secret/data/ruby-core/tls/gateway
# VAULT_TLS_PATH_ENGINE=secret/data/ruby-core/tls/engine

# =============================================================================
# Service Configuration
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Environment name
ENVIRONMENT=production

# =============================================================================
# Release Version
# =============================================================================
# VERSION is derived at deploy time from the git tag — do not set here.
# CI passes VERSION=${{ github.ref_name }} explicitly.
# Local deploys: VERSION is derived via `git describe --tags --abbrev=0`
# if not set in the environment. Override with VERSION=vX.Y.Z make deploy-prod.

# GitHub repository owner for GHCR image paths
GITHUB_REPOSITORY_OWNER=your-org

# =============================================================================
# Clock Skew Tolerance (ADR-0026)
# =============================================================================
# Tolerance window in milliseconds for time-sensitive operations
CLOCK_SKEW_TOLERANCE_MS=1000

# =============================================================================
# Observability — OpenTelemetry (ADR-0004, PLAN-0009)
# =============================================================================
# App services export traces + metrics via OTLP gRPC to the Foundation collector.
# These are set directly in compose.prod.yaml (not via .env):
#   OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
#   OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# They reach the collector over the external `observability` Docker network
# (owned by /opt/foundation/observability). If that network or the collector is
# absent, export degrades to a background no-op — services still start.
# deployment.environment is taken from ENVIRONMENT (=production) unless
# OTEL_DEPLOYMENT_ENVIRONMENT overrides it (staging sets that to "staging").
# Logs stay on stdout (scraped by promtail into Loki) and carry trace_id/span_id.
