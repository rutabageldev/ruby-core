# Ruby Core Staging Environment Configuration
# Phase 8: Staging for pre-release smoke testing
#
# Copy to .env and fill in VAULT_TOKEN before running make staging-up:
#   cp deploy/staging/.env.example deploy/staging/.env
#
# One-time node setup:
#   make setup-staging-creds   # generates secret/ruby-core/staging/* in Vault
#   make ghcr-login            # authenticates Docker with GHCR (persists)

VERSION=v0.10.4
VAULT_TOKEN=
VAULT_ADDR=https://127.0.0.1:8200
VAULT_CACERT=/opt/foundation/vault/tls/vault-ca.crt
GITHUB_REPOSITORY_OWNER=primaryrutabaga
